# Security: Block sensitive data formats
*.xlsx
*.xls
*.csv
*.sql
*.db
*.json
!data.js
!logs.json
!bu_ranking_cache.json

# Security: Block developer/server files
*.php
*.pyc
__pycache__/
node_modules/
.env

# Workspace Isolation: Block legacy/unauthorized folders
APIupdate/
EIA dashboard/
EIA report by weekly/
EIA file/
EIA_Q2/
EPM_Com/
Executive_Summary_V25_Mar2026/
License_monitor/
backup/
chats/
tests/

# Exceptions: Allow Dashboard files
!index.html
!data.js
!assets/
!run_sync.bat
!update_dashboard.py
!EIAQ3/
!EIAQ3/**
